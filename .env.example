# RAG Eval Harness — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# =============================================================================
# REQUIRED
# =============================================================================

# OpenAI — GPT-4o judge (RAGAS + DeepEval G-Eval) + text-embedding-3-small
# This is the ONLY API key required.
OPENAI_API_KEY=sk-your-openai-key-here

# Google Cloud — service account JSON for Vertex AI Model Garden
# Used for: Claude (gold answers, SME1) + Gemini (chatbot, SME2)
# File obtained from: GCP Console > IAM & Admin > Service Accounts > Keys
GOOGLE_APPLICATION_CREDENTIALS=./credentials/client_secrets.json

# GCP project ID — also present in your service account JSON under "project_id"
VERTEX_PROJECT_ID=your-gcp-project-id

# =============================================================================
# OPTIONAL — Vertex AI settings
# =============================================================================

# Region for Vertex AI model deployment
VERTEX_REGION=us-central1

# Claude model available in Vertex AI Model Garden
# Check availability: https://cloud.google.com/vertex-ai/generative-ai/docs/partner-models/use-claude
CLAUDE_MODEL=claude-sonnet-4-6

# Gemini model for chatbot generation (native Vertex AI)
GEMINI_MODEL=gemini-2.0-flash

# =============================================================================
# OPTIONAL — OpenAI model overrides
# =============================================================================

# Model used as judge for RAGAS and DeepEval G-Eval
EVAL_MODEL=gpt-4o

# Cheaper model for lightweight secondary tasks (claim type classification)
EVAL_MODEL_MINI=gpt-4o-mini

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# OPTIONAL — RAG pipeline settings
# =============================================================================

CHROMA_PATH=./chroma_db
KNOWLEDGE_PATH=./knowledge
TOP_K_CHUNKS=4
COLLECTION_NAME=knowledge_base
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# =============================================================================
# OPTIONAL — Application settings
# =============================================================================

API_PORT=8000
UI_PORT=8501

# =============================================================================
# OPTIONAL — MLflow experiment tracking
# =============================================================================

# Uncomment to enable MLflow logging on every eval run.
# Run `mlflow ui --backend-store-uri ./mlruns --port 5000` to view results.
# MLFLOW_TRACKING_URI=./mlruns
