# Copy this file to .env and fill in your OpenAI API key.
# Only OPENAI_API_KEY is required. All other values have working defaults.

OPENAI_API_KEY=sk-your-key-here

# --- Optional overrides ---

# Path where ChromaDB persists its vector index
CHROMA_PATH=./chroma_db

# Path to the knowledge base .txt files
KNOWLEDGE_PATH=./knowledge

# Number of chunks to retrieve per query (higher = more context, more cost)
TOP_K_CHUNKS=4

# OpenAI model for chat responses
CHAT_MODEL=gpt-4o-mini

# OpenAI model used as the eval judge (faithfulness metric)
EVAL_MODEL=gpt-4o-mini

# OpenAI model for generating embeddings
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB collection name
COLLECTION_NAME=knowledge_base
